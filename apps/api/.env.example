# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-super-secret-jwt
# Settings → Database → Connection string (URI), Transaction pooler recommended
# Convert to asyncpg: postgresql+asyncpg://postgres.xxx:PASSWORD@aws-0-....pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Required unless Supabase Auth is configured above. The server refuses to
# start on the built-in default, since JWTs would otherwise be forgeable.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
API_SECRET_KEY=local-dev-fallback-not-used-with-supabase

# Exposes POST /v1/dev/activate, which grants the caller a subscription.
# Local development ONLY — startup fails if this is on while Stripe is set.
ENABLE_DEV_ENDPOINTS=false

# --- Analysis job queue ---
# Shared secret for the runner trigger (/v1/internal/jobs/run). On Vercel set
# this to the SAME value as CRON_SECRET, which Vercel Cron sends as a bearer
# token. Leave empty to disable the endpoint entirely.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JOB_RUNNER_SECRET=

# Run the analysis in-process right after enqueue. DEV ONLY — the submit
# request then blocks for the entire analysis (minutes). On a long-running
# host run the standalone runner instead: python -m app.runner_loop
JOB_RUN_INLINE=true

# How long a runner may hold a job before another may reclaim it. Must exceed
# the slowest realistic provider call.
JOB_LEASE_SECONDS=900
JOB_MAX_ATTEMPTS=3
JOB_MAX_ACTIVE_PER_USER=3

# Jobs per runner invocation. Keep at 1 on a platform with an execution cap:
# draining several sequentially risks being killed mid provider call, which
# bills for the abandoned attempt and bills again on retry.
JOB_RUNNER_BATCH_SIZE=1
# Assumed invocation budget; keep below the platform maxDuration (Vercel Pro
# fluid compute allows 800s).
JOB_RUNNER_MAX_SECONDS=750
# Refuse to claim a job with less runway than this remaining.
JOB_MIN_RUNWAY_SECONDS=300
# Idle poll interval for the standalone runner.
JOB_RUNNER_IDLE_SLEEP_SECONDS=5

# Provider keys — server only
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Must return segment timestamps: frame alignment depends on them. As of
# openai-python 2.46 only whisper-1 supports verbose_json; the gpt-4o-transcribe
# family returns json/text only. The API refuses any other value.
TRANSCRIPTION_MODEL=whisper-1

DEFAULT_MODEL=grok-4
FALLBACK_MODELS=gpt-4o,claude-sonnet-4-5

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# One-off credit pack (Stripe mode="payment"). Startup fails if this is set
# without STRIPE_SECRET_KEY — checkout would break at the point of sale.
STRIPE_CREDIT_PACK_PRICE_ID=
CREDIT_PACK_SIZE=10
STRIPE_SUCCESS_URL=https://reenigne.dev/account?checkout=success
STRIPE_CANCEL_URL=https://reenigne.dev/pricing?checkout=cancel

# --- Entitlements ---
# Reports per month — the primary quota, and the number the pricing page
# advertises (kept in sync by apps/api/tests/test_plans_parity.py). Charged on
# success, never reserved, so a failed job costs the user nothing; jobs still
# in flight hold their headroom so concurrent submissions cannot overshoot.
PRO_ANALYSES_PER_MONTH=30
# Secondary abuse guard only, deliberately generous: a normal subscriber
# should never meet it. Not the binding constraint.
PRO_MINUTES_PER_MONTH=1000

# --- Feedback triage + GitHub filing ---
# See docs/feedback-pipeline.md. All optional: unset, feedback is still
# accepted, stored and triaged — only filing and escalation stop.
TRIAGE_MODEL=gpt-4o-mini
# Fine-grained PAT, Issues read+write on ONE repo. No Contents, Pull requests
# or Actions scope — the service calls only issues endpoints.
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=
FEEDBACK_MAX_PER_USER_PER_DAY=5
FEEDBACK_MAX_PER_IP_PER_DAY=3

CORS_ORIGINS=https://reenigne.dev,https://www.reenigne.dev,http://localhost:3000,http://localhost:5173
